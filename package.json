{
  "name": "@lenne.tech/nuxt-extensions",
  "version": "1.5.4",
  "description": "Reusable Nuxt 4 composables, components, and Better-Auth integration for lenne.tech projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenneTech/nuxt-extensions.git"
  },
  "homepage": "https://github.com/lenneTech/nuxt-extensions#readme",
  "bugs": {
    "url": "https://github.com/lenneTech/nuxt-extensions/issues"
  },
  "author": "lenne.Tech <info@lenne.tech> (https://lenne.tech)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./lib": {
      "types": "./dist/runtime/lib/index.d.ts",
      "import": "./dist/runtime/lib/index.js"
    },
    "./testing": {
      "types": "./dist/runtime/testing/index.d.ts",
      "import": "./dist/runtime/testing/index.js"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "lib": [
        "./dist/runtime/lib/index.d.ts"
      ],
      "testing": [
        "./dist/runtime/testing/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "CLAUDE.md"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "prepack": "node scripts/sync-module-version.mjs && nuxt-module-build build",
    "c": "pnpm run check",
    "check": "pnpm audit && pnpm run format:check && pnpm run lint && pnpm run dev:prepare && pnpm test:types && pnpm test && pnpm run build",
    "check:fix": "pnpm install && pnpm audit --fix && pnpm run format && pnpm run lint:fix && pnpm test:types && pnpm test && pnpm run build",
    "check:naf": "pnpm install && pnpm run format && pnpm run lint:fix && pnpm test:types && pnpm test && pnpm run build",
    "cf": "pnpm run check:fix",
    "cnaf": "pnpm run check:naf",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "build": "nuxt-module-build build",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix --fix-suggestions src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "release": "pnpm format:check && pnpm lint && pnpm test:types && pnpm test && pnpm prepack"
  },
  "dependencies": {
    "@nuxt/kit": "4.4.2"
  },
  "peerDependencies": {
    "@better-auth/passkey": ">=1.0.0",
    "@playwright/test": ">=1.0.0",
    "better-auth": ">=1.0.0",
    "nuxt": ">=3.0.0",
    "tus-js-client": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": false
    },
    "@better-auth/passkey": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "tus-js-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@better-auth/passkey": "1.5.6",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.2",
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.2",
    "@vitest/coverage-v8": "4.1.2",
    "better-auth": "1.5.6",
    "happy-dom": "20.8.9",
    "nuxt": "4.4.2",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "tus-js-client": "4.3.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "brace-expansion@<2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "defu@<=6.1.4": ">=6.1.5",
      "h3@<1.15.9": ">=1.15.9",
      "lodash@<=4.17.23": ">=4.18.0",
      "minimatch@>=5.0.0 <5.1.9": "5.1.9",
      "minimatch@>=9.0.0 <9.0.9": "9.0.9",
      "minimatch@>=10.0.0 <10.2.5": "10.2.5",
      "node-forge@<1.4.0": ">=1.4.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "srvx@<0.11.13": ">=0.11.13",
      "svgo@=4.0.0": ">=4.0.1",
      "tar@<7.5.11": "7.5.11",
      "unhead@<2.1.13": ">=2.1.13",
      "vite@<7.3.2": ">=7.3.2",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt4",
    "vue3",
    "better-auth",
    "authentication",
    "passkey",
    "webauthn",
    "tus-upload",
    "file-upload",
    "lenne-tech"
  ]
}
