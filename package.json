{
  "name": "@lenne.tech/nuxt-extensions",
  "version": "1.8.4",
  "description": "Reusable Nuxt 4 composables, components, and Better-Auth integration for lenne.tech projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenneTech/nuxt-extensions.git"
  },
  "homepage": "https://github.com/lenneTech/nuxt-extensions#readme",
  "bugs": {
    "url": "https://github.com/lenneTech/nuxt-extensions/issues"
  },
  "author": "lenne.Tech <info@lenne.tech> (https://lenne.tech)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./lib": {
      "types": "./dist/runtime/lib/index.d.ts",
      "import": "./dist/runtime/lib/index.js"
    },
    "./testing": {
      "types": "./dist/runtime/testing/index.d.ts",
      "import": "./dist/runtime/testing/index.js"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "lib": [
        "./dist/runtime/lib/index.d.ts"
      ],
      "testing": [
        "./dist/runtime/testing/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "CLAUDE.md"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "prepack": "node scripts/sync-module-version.mjs && nuxt-module-build build",
    "c": "pnpm run check",
    "check": "node scripts/check.mjs",
    "check:raw": "pnpm audit && pnpm run format:check && pnpm run lint && pnpm run dev:prepare && pnpm test:types && pnpm test && pnpm run build",
    "check:fix": "pnpm install && pnpm audit --fix && pnpm run format && pnpm run lint:fix && pnpm test:types && pnpm test && pnpm run build",
    "check:naf": "pnpm install && pnpm run format && pnpm run lint:fix && pnpm test:types && pnpm test && pnpm run build",
    "cf": "pnpm run check:fix",
    "cnaf": "pnpm run check:naf",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "build": "nuxt-module-build build",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix --fix-suggestions src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "release": "pnpm format:check && pnpm lint && pnpm test:types && pnpm test && pnpm prepack"
  },
  "dependencies": {
    "@nuxt/kit": "4.4.6"
  },
  "peerDependencies": {
    "@better-auth/passkey": ">=1.0.0",
    "@playwright/test": ">=1.0.0",
    "better-auth": ">=1.0.0",
    "nuxt": ">=3.0.0",
    "tus-js-client": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": false
    },
    "@better-auth/passkey": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "tus-js-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@better-auth/passkey": "1.6.13",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.6",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "better-auth": "1.6.13",
    "happy-dom": "20.9.0",
    "nuxt": "4.4.6",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "tus-js-client": "4.3.1",
    "typescript": "5.9.3",
    "vitest": "4.1.7",
    "vue-tsc": "3.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "devalue@>=5.6.3 <=5.8.0": "5.8.1",
      "kysely@>=0.26.0 <0.28.17": "0.28.17",
      "ws@>=8.0.0 <8.20.1": "8.21.0",
      "shell-quote@<1.8.4": "1.8.4",
      "nuxt@<4.4.7": "4.4.7",
      "vite@>=7.0.0 <7.3.5": "7.3.5",
      "tar@<7.5.16": "7.5.16",
      "launch-editor@<2.14.1": "2.14.1",
      "esbuild@<0.28.1": "0.28.1",
      "@babel/core@<7.29.6": "7.29.6"
    }
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt4",
    "vue3",
    "better-auth",
    "authentication",
    "passkey",
    "webauthn",
    "tus-upload",
    "file-upload",
    "lenne-tech"
  ]
}
