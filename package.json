{
  "name": "@lenne.tech/nuxt-extensions",
  "version": "1.11.0",
  "description": "Reusable Nuxt 4 composables, components, and Better-Auth integration for lenne.tech projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenneTech/nuxt-extensions.git"
  },
  "homepage": "https://github.com/lenneTech/nuxt-extensions#readme",
  "bugs": {
    "url": "https://github.com/lenneTech/nuxt-extensions/issues"
  },
  "author": "lenne.Tech <info@lenne.tech> (https://lenne.tech)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./lib": {
      "types": "./dist/runtime/lib/index.d.ts",
      "import": "./dist/runtime/lib/index.js"
    },
    "./testing": {
      "types": "./dist/runtime/testing/index.d.ts",
      "import": "./dist/runtime/testing/index.js"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "lib": [
        "./dist/runtime/lib/index.d.ts"
      ],
      "testing": [
        "./dist/runtime/testing/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "CLAUDE.md"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "prepack": "node scripts/sync-module-version.mjs && nuxt-module-build build",
    "c": "pnpm run check",
    "check": "node scripts/check.mjs",
    "check:raw": "pnpm install --frozen-lockfile && pnpm audit && pnpm run format:check && pnpm run lint && pnpm run version:check && pnpm run dev:prepare && pnpm test:types && pnpm test && pnpm run build && pnpm run check:manifest",
    "check:fix": "pnpm install && pnpm audit --fix && pnpm run format && pnpm run lint:fix && pnpm run version:sync && pnpm test:types && pnpm test && pnpm run build && pnpm run check:manifest",
    "check:naf": "pnpm install && pnpm run format && pnpm run lint:fix && pnpm run version:sync && pnpm test:types && pnpm test && pnpm run build && pnpm run check:manifest",
    "cf": "pnpm run check:fix",
    "cnaf": "pnpm run check:naf",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "build": "nuxt-module-build build",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix --fix-suggestions src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "version:sync": "node scripts/sync-module-version.mjs",
    "version:check": "node scripts/sync-module-version.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "release": "pnpm format:check && pnpm lint && pnpm run version:check && pnpm test:types && pnpm test && pnpm run check:consumer && pnpm prepack",
    "check:consumer": "node scripts/check-consumer-build.mjs",
    "check:manifest": "node scripts/check-package-manifest.mjs"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0"
  },
  "peerDependencies": {
    "@better-auth/passkey": ">=1.0.0",
    "@playwright/test": ">=1.0.0",
    "better-auth": ">=1.0.0",
    "nuxt": "^4.0.0",
    "tus-js-client": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": false
    },
    "@better-auth/passkey": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "tus-js-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@better-auth/passkey": "1.6.23",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.8",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "better-auth": "1.6.23",
    "happy-dom": "20.10.6",
    "nuxt": "4.4.8",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tus-js-client": "4.3.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt4",
    "vue3",
    "better-auth",
    "authentication",
    "passkey",
    "webauthn",
    "tus-upload",
    "file-upload",
    "lenne-tech"
  ],
  "engines": {
    "node": ">= 22",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
